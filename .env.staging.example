# Ambiente de staging do Guia Produto Radar.
# Copie para .env.staging na VPS e troque todos os valores marcados como change-me.
# Nao use credenciais reais neste arquivo versionado.

APP_ENV=staging

# Portas publicadas somente em 127.0.0.1 na VPS.
# O Nginx externo deve fazer proxy para estas portas.
API_PORT=28080
ADMIN_PORT=28090

# Banco interno do Compose de staging.
POSTGRES_DB=guia_produto_radar_staging
POSTGRES_USER=gpr_staging_user
POSTGRES_PASSWORD=change-me-staging-postgres-password

DATABASE_URL=postgresql+psycopg://gpr_staging_user:change-me-staging-postgres-password@postgres:5432/guia_produto_radar_staging
REDIS_URL=redis://redis:6379/0

# Origens autorizadas para o admin consumir a API pelo navegador.
ADMIN_CORS_ORIGINS=https://radar-staging.guiaproduto.com.br,http://127.0.0.1:28090

WORKER_HEARTBEAT_SECONDS=60

# Deploy manual.
GPR_BRANCH=main
GPR_HEALTH_URL=http://127.0.0.1:28080/health
GPR_BACKUP_DIR=/var/backups/guia-produto-radar/staging
GPR_ROLLBACK_ON_FAILURE=1
GPR_RUN_TESTS=0

# Conectores de dados. Nesta fase, todos usam mocks deterministas.
GPR_CONNECTOR_GOOGLE_TRENDS_ENABLED=true
GPR_CONNECTOR_GOOGLE_TRENDS_RATE_LIMIT_PER_MINUTE=60
GPR_CONNECTOR_GOOGLE_ADS_KEYWORD_PLANNER_ENABLED=true
GPR_CONNECTOR_GOOGLE_ADS_KEYWORD_PLANNER_RATE_LIMIT_PER_MINUTE=30
GPR_CONNECTOR_GOOGLE_SEARCH_CONSOLE_ENABLED=true
GPR_CONNECTOR_GOOGLE_SEARCH_CONSOLE_RATE_LIMIT_PER_MINUTE=60
GPR_CONNECTOR_AMAZON_CREATORS_ENABLED=true
GPR_CONNECTOR_AMAZON_CREATORS_RATE_LIMIT_PER_MINUTE=30
GPR_CONNECTOR_MERCADO_LIVRE_ENABLED=true
GPR_CONNECTOR_MERCADO_LIVRE_RATE_LIMIT_PER_MINUTE=30
GPR_CONNECTOR_SHOPEE_ENABLED=true
GPR_CONNECTOR_SHOPEE_RATE_LIMIT_PER_MINUTE=30
GPR_CONNECTOR_SERP_API_ENABLED=true
GPR_CONNECTOR_SERP_API_RATE_LIMIT_PER_MINUTE=20
GPR_CONNECTOR_INTERNAL_DATA_ENABLED=true
GPR_CONNECTOR_INTERNAL_DATA_RATE_LIMIT_PER_MINUTE=120

# Reservado para fases futuras. Preencher apenas fora do git.
WORDPRESS_API_TOKEN=
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
MERCADO_LIVRE_CLIENT_ID=
MERCADO_LIVRE_CLIENT_SECRET=
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
