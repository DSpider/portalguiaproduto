# Ambiente local de desenvolvimento.
# Copie para .env se quiser alterar portas ou valores locais.
# Nao use credenciais reais neste arquivo.

APP_ENV=local
API_PORT=18080
POSTGRES_PORT=15432
REDIS_PORT=16379

POSTGRES_DB=guia_produto_radar
POSTGRES_USER=gp_local_user
POSTGRES_PASSWORD=gp_local_password_change_me

DATABASE_URL=postgresql+psycopg://gp_local_user:gp_local_password_change_me@postgres:5432/guia_produto_radar
REDIS_URL=redis://redis:6379/0
ADMIN_CORS_ORIGINS=http://localhost:18090,http://127.0.0.1:18090

WORKER_HEARTBEAT_SECONDS=30

# Conectores de dados. Nesta fase, todos usam mocks deterministas.
GPR_CONNECTOR_GOOGLE_TRENDS_ENABLED=true
GPR_CONNECTOR_GOOGLE_TRENDS_RATE_LIMIT_PER_MINUTE=60
GPR_CONNECTOR_GOOGLE_ADS_KEYWORD_PLANNER_ENABLED=true
GPR_CONNECTOR_GOOGLE_ADS_KEYWORD_PLANNER_RATE_LIMIT_PER_MINUTE=30
GPR_CONNECTOR_GOOGLE_SEARCH_CONSOLE_ENABLED=true
GPR_CONNECTOR_GOOGLE_SEARCH_CONSOLE_RATE_LIMIT_PER_MINUTE=60
GPR_CONNECTOR_AMAZON_CREATORS_ENABLED=true
GPR_CONNECTOR_AMAZON_CREATORS_RATE_LIMIT_PER_MINUTE=30
GPR_CONNECTOR_MERCADO_LIVRE_ENABLED=true
GPR_CONNECTOR_MERCADO_LIVRE_RATE_LIMIT_PER_MINUTE=30
GPR_CONNECTOR_SHOPEE_ENABLED=true
GPR_CONNECTOR_SHOPEE_RATE_LIMIT_PER_MINUTE=30
GPR_CONNECTOR_SERP_API_ENABLED=true
GPR_CONNECTOR_SERP_API_RATE_LIMIT_PER_MINUTE=20
GPR_CONNECTOR_INTERNAL_DATA_ENABLED=true
GPR_CONNECTOR_INTERNAL_DATA_RATE_LIMIT_PER_MINUTE=120

# Reservado para fases futuras. Preencher apenas fora do git.
WORDPRESS_API_TOKEN=
AMAZON_CREDENTIAL_ID=
AMAZON_CREDENTIAL_SECRET=
AMAZON_CREATORS_VERSION=2.1
AMAZON_ACCESS_KEY=
AMAZON_SECRET_KEY=
MERCADO_LIVRE_CLIENT_ID=
MERCADO_LIVRE_CLIENT_SECRET=
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
